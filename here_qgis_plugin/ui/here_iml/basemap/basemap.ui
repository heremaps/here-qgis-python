<ui version="4.0">
 <class>BasemapPopup</class>
 <widget class="QDialog" name="BasemapPopup">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>350</width>
    <height>400</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Select Base Map Style</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <layout class="QVBoxLayout" name="formLayout">
     <item>
      <widget class="QLabel" name="imageFormatLabel">
       <property name="text">
        <string>Image Format:</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="imageFormatDropdown"/>
     </item>
     <item>
      <widget class="QLabel" name="imageSizeLabel">
       <property name="text">
        <string>Image Size:</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="imageSizeDropdown"/>
     </item>
     <item>
      <widget class="QLabel" name="mapStyleLabel">
       <property name="text">
        <string>Map Tile Style:</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="mapStyleDropdown"/>
     </item>
     <item>
      <widget class="QLabel" name="languageLabel">
       <property name="text">
        <string>Language [optional]:</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="languageDropdown"/>
     </item>
     <item>
      <widget class="QLabel" name="languageSecLabel">
       <property name="text">
        <string>Language (secondary) [optional]:</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="languageSecDropdown"/>
     </item>
     <item>
      <widget class="QLabel" name="pviewLabel">
